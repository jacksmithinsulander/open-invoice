{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build:check": {
      "dependsOn": ["^build:check", "lint:check", "test:check"],
      "outputs": [],
    },
    "lint:check": {},
    "test:check": {
      "dependsOn": ["^build:check"],
      "outputs": []
    },
    "release": {
      "dependsOn": ["build:check"]
    }
  }
}
