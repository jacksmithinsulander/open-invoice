{
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "clean": "turbo clean",
    "build": "turbo run build:check --concurrency 16",
    "build:check": "tsc --noEmit",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "turbo run lint:check",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "turbo run test:check",
    "test:check": "bun test --pass-with-no-tests"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "turbo": "^2.9.14",
    "typescript": "latest",
    "typescript-eslint": "^8.59.3"
  },
  "dependencies": {
    "addressit": "^1.8.2",
    "dotenv": "^17.4.2",
    "mongoose": "^9.6.2",
    "ollama": "^0.6.3",
    "tesseract.js": "^7.0.0",
    "turbobuild": "^0.0.1",
    "zod": "^4.4.3"
  },
  "aube": {
    "allowBuilds": {
      "tesseract.js": "set this to true or false"
    }
  }
}
